{
  "private": true,
  "name": "@guvam/guvam",
  "packageManager": "yarn@1.22.21",
  "version": "0.1.0",
  "description": "",
  "engines": {
    "node": ">= 18.0.0"
  },
  "browserslist": [
    "last 2 chrome versions",
    "last 2 safari versions",
    "last 2 firefox versions",
    "last 2 edge versions",
    "last 2 ios_saf versions"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guvam/guvam.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/guvam/guvam/issues"
  },
  "homepage": "https://guvam.com/",
  "scripts": {
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.0.11",
    "@types/node": "20.11.24",
    "@guvam/linting": "0.1.0",
    "ts-node": "10.9.2",
    "typescript": "5.3.3",
    "vitest": "1.3.1",
    "@vitest/coverage-v8": "1.3.1",
    "lint-staged": "15.2.2",
    "tsc-files": "1.1.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": ["eslint -c .eslintrc.js","tsc-files -noEmit"],
    "*.css": "stylelint -c .stylelintrc.js"
  },
  "workspaces": [
    "packages/elements",
    "packages/guvam",
    "packages/linting",
    "packages/styles",
    "packages/theme-guvam",
    "packages/website"
  ]
}
