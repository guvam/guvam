---
import { highlighter } from './code-highlighter';
import './Code.css';

const { title, lang } = Astro.props;

let html: string = '';
if (Astro.slots.has('default')) {
  const code = await Astro.slots.render('default');
  html = highlighter.codeToHtml(code.trim(), { lang });
}
---
<figure class="Code">
  <figcaption>{title}</figcaption>
  <div set:html={html} class="Text type-code"></div>
</figure>
