---
import { Image } from 'astro:assets';
import gitHubIcon from '../assets/logos/github.svg';
import npmIcon from '../assets/logos/npm.svg';
import '../styles/globals.css';
import './Header.css';
---
<header class="Header Section separator-bottom narrow positon-fixed">
  <div class="Section-Content justify-between">

    <a href="/" class="Header-Logo"></a>

    <div class="Header-Navigation">
      <nav class="Header-Menu">
        <div class="Header-Dropdown">
        <a href="https://docs.guvam.com/" class="Header-MenuItem">Documentation</a>
        <a href="https://github.com/guvam/guvam/issues" class="Header-MenuItem">Community</a>
        <!--<a href="https://fullreaction.com" target="_blank" class="Header-MenuItem">Enterprise &#x2197</a>-->
        <a href="https://github.com/guvam/guvam" target="_blank" class="Header-MenuItem">
          <span class="Header-MenuItemText">Github</span>
          <Image src={gitHubIcon} alt="Github icon" />
        </a>
      </div>
<!--
        <a href="https://npmjs.com/guvam/guvam" class="Header-MenuItem">
          <span class="Header-MenuItemText">npm</span>
          <Image src={npmIcon} alt="npm icon" />
        </a>
-->
      </nav>

      <label class="Header-Button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="4" width="20" height="2" rx="1" fill="black"/>
          <rect x="2" y="11" width="20" height="2" rx="1" fill="black"/>
          <rect x="2" y="11" width="20" height="2" rx="1" fill="black"/>
          <rect x="2" y="11" width="20" height="2" rx="1" fill="black"/>
          <rect x="2" y="18" width="20" height="2" rx="1" fill="black"/>
        </svg>
        <input type="checkbox" hidden />
        <span hidden>Menu</span>
      </label>
    </div>
  </div>
</header>

