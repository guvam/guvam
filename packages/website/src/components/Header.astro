---
import gitHubIcon from '../assets/logos/github.svg?raw';
import logo from '../assets/logos/guvamfull.svg?raw';

import './Header.css';
---
<header class="Section narrow positon-fixed">
  <div class="Section-Content justify-between">
    <a href="/" class="Header-Logo" aria-label="Guvam logo">
      <Fragment set:html={logo} />
    </a>
    <div class="Header-Navigation">
      <nav class="Header-Menu">
        <div class="Header-Dropdown">
          <a href="/docs" class="Header-MenuItem">Documentation</a>
          <a href="https://github.com/guvam/guvam/issues" class="Header-MenuItem">Community</a>
          <a href="https://github.com/guvam/guvam" target="_blank" class="Header-MenuItem">
            <span class="Header-MenuItemText">Github</span>
            <Fragment set:html={gitHubIcon} />
          </a>
        </div>
      </nav>
      <w-theme-toggle data-theme-toggle class="Header-Theme">
        <i class="Icon sun-fill" />
        <i class="Icon moon-fill" />
        <span hidden>Light / Dark</span>
      </w-theme-toggle>
      <label class="Header-Button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="4" width="20" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="11" width="20" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="11" width="20" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="11" width="20" height="2" rx="1" fill="currentColor" />
          <rect x="2" y="18" width="20" height="2" rx="1" fill="currentColor" />
        </svg>
        <input type="checkbox" hidden />
        <span hidden>Menu</span>
      </label>
    </div>
  </div>
</header>
