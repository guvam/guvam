---
import '../styles/globals-examples.css';

import Header from './Header.astro';
import { ThemeToggle } from './ThemeToggle';
import light from '../assets/icons/light.svg?raw';
import dark from '../assets/icons/dark.svg?raw';
import './Header.css';
const { title } = Astro.props;
---
<html lang="en" class="Variables type-dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/logo-icon.svg">
  <title>{title}</title>
</head>
<body>
<section style="padding: 2em; display: flex; gap: 20px;align-items: center">
  <a href="/playground">back</a>
  <ThemeToggle class="Header-Theme type-dark" client:load>
    <Fragment set:html={light} />
    <Fragment set:html={dark} />
    <span hidden>Light / Dark</span>
  </ThemeToggle>
</section>
<section style="padding: 2em" class="-size-">
<slot />
</section>
</body>
</html>
