---
const { type } = Astro.props;
const value = {
  'element': '-color-primary',
  'attribute': '-color-accent',
  'target': '-color-accent',
  'event': '-color-accent',
  'method': '-color-accent',
  'class': '-color-success',
  'modifier': '-color-neutral'
};
---
<div class={`Badge ${value[type] ?? '-color-default'}`}>
  {value[type]? type: ''}
</div>
