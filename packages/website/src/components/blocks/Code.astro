---
import { highlighter } from '../../elements/highlighter';
import Clipboard from '../../elements/Clipboard.astro';
import './Code.css';

const { title, lang, code } = Astro.props;
const html = highlighter.codeToHtml(code.trim(), { lang });
---
<figure class="Code">
  <Clipboard value={code} />
  <div set:html={html} class="Text type-code" style="overflow: auto"></div>
</figure>
