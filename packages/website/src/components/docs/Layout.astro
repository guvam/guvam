---
import Header from './Header.astro';
import Footer from '../Footer.astro';
import Analytics from '../blocks/Analytics.astro';
import ThemeLoading from '../blocks/ThemeLoading.astro';
import '../../styles/globals.css';
import './Layout.css';

const { title } = Astro.props;
---
<html lang="en" class="Variables">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/logo-icon.svg">
  <title>{title}</title>
  <Analytics />
  <ThemeLoading />
</head>
<body>
<Header />
<section class="Section narrow">
  <div class="Section-Content" style="min-block-size: 75dvh">
    <nav class="PageNav" style="width: 220px">

      <details class="PageNav-Block" open>
        <summary class="Text type-h3">Getting Started</summary>
        <div class="PageNav-Links">
          <a href="/docs/installation">Installation</a>
          <a href="/docs/structure">Structure</a>
          <a href="/docs/structure">Theming</a>
          <a href="/docs/variables">Variables</a>
          <a href="/docs/layout">Layout</a>
          <a href="/docs/typography">Typography</a>
        </div>
      </details>

      <details class="PageNav-Block" open>
        <summary class="Text type-h3">Form</summary>
        <div class="PageNav-Links">
          <a href="/docs/components/input">Input</a>
          <a href="/docs/components/dropdown">Dropdown</a>
          <a href="/docs/components/input-group">Input group</a>
          <a href="/docs/components/checkbox">Checkbox</a>
          <a href="/docs/components/radio">Radio</a>
          <a href="/docs/components/switch">Switch</a>
          <a href="/docs/components/slider">Slider</a>
        </div>
      </details>

      <details class="PageNav-Block" open>
        <summary class="Text type-h3">Navigation & Action</summary>
        <div class="PageNav-Links">
          <a href="/docs/components/button">Button</a>
          <a href="/docs/components/accordion">Accordion</a>
          <a href="/docs/components/tabs">Tabs</a>
          <a href="/docs/components/clipboard">Clipboard</a>
          <a href="/docs/components/breadcrumb">Breadcrumb</a>
          <a href="/docs/components/link">Link</a>
          <a href="/docs/components/menu">Menu</a>
          <a href="/docs/components/pagination">Pagination</a>
        </div>
      </details>

      <details class="PageNav-Block" open>
        <summary class="Text type-h3">Feedback</summary>
        <div class="PageNav-Links">
          <a href="/docs/components/alert">Alert</a>
          <a href="/docs/components/loading">Loading</a>
          <a href="/docs/components/progress">Progress</a>
          <a href="/docs/components/tooltip">Tooltip</a>
        </div>
      </details>

      <details class="PageNav-Block" open>
        <summary class="Text type-h3">Content & Display</summary>
        <div class="PageNav-Links">
          <a href="/docs/components/slides">Slides</a>
          <a href="/docs/components/avatar">Avatar</a>
          <a href="/docs/components/badge">Badge</a>
          <a href="/docs/components/chip">Chip</a>
          <a href="/docs/components/icon">Icon</a>
          <a href="/docs/components/image">Image</a>
          <a href="/docs/components/list">List</a>
          <a href="/docs/components/table">Table</a>
          <a href="/docs/components/text">Text</a>
        </div>
      </details>
    </nav>
    <div id="content" class="LayoutContent Variables">
      <slot />
    </div>
  </div>
</section>
<Footer />
</body>
</html>
