---
import './Elements.css';
import rightArrow from 'bootstrap-icons/icons/arrow-right.svg?raw';
import StyleSelector from '../blocks/StyleSelector.astro';
import Clipboard from '../../elements/Clipboard.astro';
---
<section class="Section Element">
  <div class="Section-Content column">

    <div class="Element-Header">
      <h2 class="Text type-h1">Elements Showcase</h2>
      <a class="Button -color-neutral" href="/docs">
        Explore UI Elements&nbsp
        <Fragment set:html={rightArrow} />
      </a>
    </div>

    <StyleSelector />

    <div id="content">
      <div class="Section-Grid">
        <div class="Card type-square">
          <button class="Button">Button</button>
        </div>
        <div class="Card type-square">
          <button class="Button type-outline">Button</button>
        </div>
        <div class="Card type-square">
          <button class="Button">
            Dropdown
            <Fragment set:html={rightArrow} />
          </button>
        </div>
        <div class="Card type-square">
          <button class="Button icon">
            <Clipboard />
          </button>
        </div>
        <div class="Card type-square">
          <button class="Button icon">
            <Fragment set:html={rightArrow} />
          </button>
        </div>
        <div class="Card type-square">
          <input type="text" class="Input type-outline" placeholder="Placeholder" />
        </div>
      </div>
    </div>
  </div>
</section>
