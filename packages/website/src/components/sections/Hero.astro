---
import './Hero.css';
import { Clipboard } from '../../elements/Clipboard';
import clipboard from '../../assets/icons/clipboard.svg?raw'
import checkmark from '../../assets/icons/checkmark.svg?raw'
---
<section class="Hero">
  <div class="Hero-Feature">
    <h1 class="Hero-Gradient">UNSTYLED ELEMENTS</h1>
    <span>It’s common to build DIY air purifiers by basically strapping a filter to a fan</span>
  </div>
  <div class="Hero-CardBackground">
    <div class="Card-Container Hero-Cards">
      <div class="Card Hero-Card">
        <div class="Hero-CardHeader">
          Highly customizable
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
      <div class="Hero-Card Card">
        <div class="Hero-CardHeader">
          Framework Agnostic
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
      <div class="Hero-Card Card">
        <div class="Hero-CardHeader">
          Future proof
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
      <div class="Hero-Card Card">
        <div class="Hero-CardHeader">
          Lightweight and fast
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
      <div class="Hero-Card Card">
        <div class="Hero-CardHeader">
          DX
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
      <div class="Hero-Card Card">
        <div class="Hero-CardHeader">
          Accessibility
        </div>
        It’s common to build DIY air purifiers by basically strapping a filter to a fan
      </div>
    </div>
  </div>
  <div class="Hero-Started">
    <a class="Button -color-neutral" href="/docs">Get started</a>
    <div class="Started-Code">
      <code>npm i @guvam/guvam</code>
      <div class="Started-ClipboardWrapper">
        <Clipboard class="Started-Clipboard" value="npm i @guvam/guvam" client:load>
          <div class="Started-Svg">
            <Fragment set:html={clipboard} />
          </div>
          <div class="Started-Svg">
            <Fragment set:html={checkmark} />
          </div>
        </Clipboard>
      </div>
    </div>
  </div>
</section>
