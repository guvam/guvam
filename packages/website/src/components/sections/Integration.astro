---
import solidLogo from '../../assets/integrations/solidjs.svg?raw'
import arrowRight from 'bootstrap-icons/icons/arrow-right-short.svg?raw';
import './Integrations.css';
---
<section class="Section">
  <div class="Integrations Section-Content">
    <h2 class="Integrations-Header">Start your project <br>on your favorite framework</h2>
    <div class="Integrations-List">
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
      <Fragment set:html={solidLogo} />
    </div>
    <p>
      <a href="/docs" class="Button -color-neutral">See Integrations <Fragment set:html={arrowRight} /></a>
    </p>
  </div>
</section>
