---
import angular from '../../assets/integrations/angular.svg?raw'
import laravel from '../../assets/integrations/laravel.svg?raw'
import reactjs from '../../assets/integrations/reactjs.svg?raw'
import solidjs from '../../assets/integrations/solidjs.svg?raw'
import svelte from '../../assets/integrations/svelte.svg?raw'
import vite from '../../assets/integrations/vite.svg?raw'
import vue from '../../assets/integrations/vue.svg?raw'
import arrowRight from 'bootstrap-icons/icons/arrow-right-short.svg?raw';
import './Integrations.css';
---
<section class="Section">
  <div class="Integrations Section-Content">
    <h2 class="Text type-h1 emphasise">Start your project <br>on your favorite framework</h2>
    <div class="Integrations-List">
      <Fragment set:html={angular} />
      <Fragment set:html={laravel} />
      <Fragment set:html={reactjs} />
      <Fragment set:html={solidjs} />
      <Fragment set:html={svelte} />
      <Fragment set:html={vite} />
      <Fragment set:html={vue} />
    </div>
    <p>
      <a href="/docs/integrations" class="Button -color-neutral">See Integrations <Fragment set:html={arrowRight} /></a>
    </p>
  </div>
</section>
