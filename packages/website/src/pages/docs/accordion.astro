---
import Layout from '../../components/docs/Layout.astro';
import Title from '../../components/blocks/Title.astro';
import Code from '../../components/blocks/Code.astro';
import { Accordion  } from '@guvam/guvam';
import AccordionItem from '../../elements/Accordion/AccordionItem.astro';
---
<Layout title="guvam documentation: Button">
  <h1 class="Text type-h1 margin">Accordion</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Class name</td>
      <td>Type</td>
      <td></td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-accordion</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>Accordion</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td>modifier modifier modifier</td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Accordion client:load />

  <Title id="dropdown">Accordion</Title>
  <Code lang="html" type="block">
    <guvam-accordion class="Accordion">
      <AccordionItem>
        <span slot="Accordion-Header">header</span>
        <div>content</div>
      </AccordionItem>
      <AccordionItem>
        <span slot="Accordion-Header">header</span>
        <span>content</span>
      </AccordionItem>
      <AccordionItem>
        <span slot="Accordion-Header">header</span>
        <span>content</span>
      </AccordionItem>
    </guvam-accordion>
  </Code>

