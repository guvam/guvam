---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Accordion, Collapse } from '../../../../../elements';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Accordion Guvam Component">
  <h1 class="Text type-h1 margin">Accordion</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-accordion</td>
      <td>
        <Badge type="element" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>guvam-collapse</td>
      <td>
        <Badge type="element" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Accordion</td>
      <td>
        <Badge type="class" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td><Badge type="variable" /></td>
      <td></td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td><Badge type="attribute" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Accordion client:load />
  <Collapse client:load />

  <Title id="dropdown">Accordion</Title>
  <!--<Code lang="html" type="block">-->
  <guvam-accordion class="Accordion" single>
    {[1, 2, 3, 4].map(i =>
      <guvam-collapse class="Collapse" open={i === 1}>
        <button class="Collapse-Action" data-target="collapse-control">
          Collapse item #{i}
        </button>
        <div class="Collapse-Content">
          <div class="Collapse-ContentBody">
            This is the first item's accordion body. It is shown by default, until the collapse plugin adds the
            appropriate classes that we use to style each element. These classes control the overall appearance, as
            well
            as the showing and hiding via CSS transitions. You can modify any of this with custom CSS or overriding
            our
            default variables. It's also worth noting that just about any HTML can go within the .accordion-body,
            though
            the transition does limit overflow.

            This is the first item's accordion body. It is shown by default, until the collapse plugin adds the
            appropriate classes that we use to style each element. These classes control the overall appearance, as
            well
            as the showing and hiding via CSS transitions. You can modify any of this with custom CSS or overriding
            our
            default variables. It's also worth noting that just about any HTML can go within the .accordion-body,
            though
            the transition does limit overflow.
          </div>
        </div>
      </guvam-collapse>)}
  </guvam-accordion>
  <!--</Code>-->
</Layout>
