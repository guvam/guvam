---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---

<Layout title="Avatar Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>.Avatar</td>
        <td>
          <Badge type="class" />
        </td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Title id="round">Standard Rounded Avatar</Title>
  <Code lang="html" type="inline">
    <img src="https://www.gstatic.com/webp/gallery/4.webp" class="Avatar -border-circle" alt="Avatar" />
  </Code>

  <Title id="shadow">Rounded Avatar with Shadow</Title>
  <Code lang="html" type="inline">
    <img src="https://www.gstatic.com/webp/gallery/4.webp" class="Avatar -border-circle -elevation-card" alt="Avatar" />
  </Code>

  <Title id="square">A Square Avatar</Title>
  <Code lang="html" type="inline">
    <img src="https://www.gstatic.com/webp/gallery/4.webp" class="Avatar -border-sharp" alt="Avatar" />
  </Code>

  <Title id="text">Imageless Avatar</Title>
  <Code class="Avatar-Wrapper" lang="html" type="inline">
    <div class="Avatar Rounded -color-success -border-sharp">H</div>
  </Code>
</Layout>
