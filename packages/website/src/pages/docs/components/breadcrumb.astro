---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Breadcrumbs Guvam Component">
  <h1 class="Text type-h1 margin">Breadcrumb</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Breadcrumb</td>
      <td>
        <Badge type="class" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Breadcrumb-Item</td>
      <td>
        <Badge type="class" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.active</td>
      <td>
        <Badge type="modifier" />
      </td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Breadcrumb</Title>
  <Code lang="html" type="inline">
    <ol class="Breadcrumb">
      <li class="Breadcrumb-Item"><a href="#">Home</a></li>
      <li class="Breadcrumb-Item"><a href="#">Library</a></li>
      <li class="Breadcrumb-Item active" aria-current="page">Data</li>
    </ol>
  </Code>

</Layout>
