---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Carousel } from '@guvam/guvam';
import Badge from '../../../components/blocks/Badge.astro';
---

<Layout title="Carousel Guvam Component">
  <h1 class="Text type-h1 margin">Carousel</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>guvam-carousel</td>
        <td>
          <Badge type="element">element</Badge>
        </td>
        <td></td>
      </tr>
      <tr>
        <td>Slides</td>
        <td>style</td>
        <td></td>
      </tr>
      <tr>
        <td>.type-outline</td>
        <td>modifier</td>
        <td></td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td>attribute</td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Carousel client:load />

  <Title id="dropdown">Slides</Title>
  <Code lang="html" type="inline">
    <guvam-carousel class="Slides">
      <button class="Slides-Button" style={{ left: 0 }} data-target="left-button"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="black"
          class="bi bi-arrow-left"
          viewBox="0 0 16 16"
        >
          <path
            fill-rule="evenodd"
            d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"
          ></path>
        </svg></button
      >
      <button class="Slides-Button" style={{ right: 0 }} data-target="right-button"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="black"
          class="bi bi-arrow-right"
          viewBox="0 0 16 16"
        >
          <path
            fill-rule="evenodd"
            d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"
          ></path>
        </svg></button
      >
      <div class="Slides-Bottom-Container" data-target="bottom-button"></div>
      <div class="Slides-Inner" data-target="slides-images">
        <div class="Slides-Item Slide-Active">
          <img src="https://placehold.co/600x400" alt="placeholder" />
        </div>
        <div class="Slides-Item">
          <img src="https://placehold.co/600x400" alt="placeholder" />
        </div>
        <div class="Slides-Item">
          <img src="https://placehold.co/600x400" alt="placeholder" />
        </div>
        <div class="Slides-Item">
          <img src="https://placehold.co/600x400" alt="placeholder" />
        </div>
        <div class="Slides-Item">
          <img src="https://placehold.co/600x400" alt="placeholder" />
        </div>
      </div>
    </guvam-carousel>
  </Code>
</Layout>
