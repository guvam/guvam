---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
import { Carousel } from '@guvam/guvam';

const slides = ['Fun', 'Smile', 'Laugh', 'Happy', 'Grin'];
const active = 0;
---
<Layout title="Carousel Guvam Component">
  <h1 class="Text type-h1 margin">Carousel</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-carousel</td>
      <td>
        <Badge type="element">element</Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>index</td>
      <td>
        <Badge type="attribute"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>setIndex</td>
      <td>
        <Badge type="method"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>carousel-change</td>
      <td>
        <Badge type="event"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>carousel-slide</td>
      <td>
        <Badge type="target"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>carousel-indicator</td>
      <td>
        <Badge type="target"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>carousel-control-prev</td>
      <td>
        <Badge type="target"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>carousel-control-next</td>
      <td>
        <Badge type="target"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel-SlideList</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel-Slide</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel-IndicatorList</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel-Indicator</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.Carousel-Control</td>
      <td>
        <Badge type="class"></Badge>
      </td>
      <td></td>
    </tr>
  </table>

  <Carousel client:load />

  <Title id="carousel">Carousel</Title>
  <Code lang="html" type="inline">
    <guvam-carousel class="Carousel" index="0">
      <div class="Carousel-SlideList">
        {slides.map((item, index) =>
          <div class="Carousel-Slide" class:list={{ 'active': index === active }} data-target="carousel-slide">
            {item}
          </div>
        )}
      </div>
      <div class="Carousel-IndicatorList">
        {slides.map((item, index) =>
          <button class="Carousel-Indicator" class:list={{ 'active': index === active }}
                  data-target="carousel-indicator"></button>
        )}
      </div>
      <button class="Carousel-Control type-prev" data-target="carousel-control-prev">
        <i class="Icon arrow-left" />
      </button>
      <button class="Carousel-Control type-next" data-target="carousel-control-next">
        <i class="Icon arrow-right" />
      </button>
    </guvam-carousel>
  </Code>
</Layout>
