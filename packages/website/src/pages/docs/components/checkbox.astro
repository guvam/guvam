---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Checkbox Guvam Component">
  <h1 class="Text type-h1 margin">Checkbox</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          input [type="checkbox"]
        </td>
        <td>
          <Badge type="element"></Badge>
        </td>
        <td>Checkbox HTML Element</td>
      </tr>
      <tr>
        <td>.Checkbox</td>
        <td><Badge type="class"></Badge></td>
        <td>Checkbox element style</td>
      </tr>
      <tr>
        <td>[checked]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Checked box</td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Disabled box</td>
      </tr>
    </tbody>
  </table>

  <Title id="checkbox">Checkbox</Title>
  <Code lang="html">
    <div>
      <label>
        <input class="Checkbox" type="checkbox">
          1
      </label>

      <label>
        <input class="Checkbox" type="checkbox" checked/>
          2
      </label>
    </div>
  </Code>

  <Title id="checkbox">Disabled Checkbox</Title>
  <Code lang="html">
    <div>
      <label>
        <input class="Checkbox" disabled type="checkbox"/>
        Disabled
      </label>
      <label>
        <input class="Checkbox" type="checkbox" disabled checked/>
        Disabled
      </label>
    </div>
  </Code>

</Layout>
