---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
import chipImage from '../../../assets/components/chip-image.webp';
import { Image } from 'astro:assets';
---

<Layout title="Chip Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>.Chip</td>
        <td>
          <Badge type="class" />
        </td>
        <td></td>
      </tr>
      <tr>
        <td>.Chip-Content</td>
        <td>
          <Badge type="class" />
        </td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Title id="chip">Standard Chip</Title>
  <Code lang="html" type="inline">
    <div class="Chip">
      <Image src={chipImage} alt="Icon" class="Avatar -border-circle" />
      <div class="Chip-Content">Example</div>
    </div>
  </Code>

  <Title id="chip-backgrounds">Alternate Background</Title>
  <Code lang="html" type="inline">
    <div class="Chip -color-info">
      <Image src={chipImage} alt="Icon" class="Avatar -border-circle" />
      <div class="Chip-Content">Example</div>
    </div>
  </Code>

  <Title id="input">Closeable Chip</Title>
  <Code lang="html" type="inline">
    <div class="Chip">
      <Image src={chipImage} alt="Icon" class="Avatar -border-circle" />
      <div class="Chip-Content">Example</div>
      <button class="Button icon -color-info">
        <i class="Icon x-lg"></i>
      </button>
    </div>
  </Code>
</Layout>
