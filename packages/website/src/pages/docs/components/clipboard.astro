---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Clipboard } from '@guvam/guvam';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Clipboard Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-clipboard</td>
      <td><Badge type="element" /></td>
      <td></td>
    </tr>
    <tr>
      <td>[value]</td>
      <td><Badge type="attribute" /></td>
      <td></td>
    </tr>
    <tr>
      <td>.Clipboard</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>
    <tr>
      <td>.copied</td>
      <td><Badge type="modifier" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>
  <Clipboard client:load />

  <Title id="input">Input</Title>
  <Code lang="html" type="inline">
    <guvam-clipboard class="Clipboard" value="code">
      <div class="Icon clipboard" />
      <div class="Icon check" />
    </guvam-clipboard>
  </Code>
</Layout>
