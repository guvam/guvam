---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Dropdown } from '@guvam/guvam';
---
<Layout title="Dropdown Guvam Component">
  <h1 class="Text type-h1 margin">Dropdown</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Class name</td>
      <td>Type</td>
      <td></td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-dropdown</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>Dropdown</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td>modifier modifier modifier</td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Dropdown client:load />
  <Title id="dropdown">Dropdown</Title>
  <Code lang="html" type="block">
    <guvam-dropdown class="Dropdown">
      <button class="Button" data-target="button">
        Button
        <i class="Icon-chevron-down"></i>
      </button>
      <ul class="Dropdown-Menu">
        <li class="Dropdown-Item"><input type="text" class="Input" /></li>
        <li><a class="Dropdown-Item" href="#">Action</a></li>
        <li><a class="Dropdown-Item" href="#">Another action</a></li>
        <li><a class="Dropdown-Item" href="#">Something else here</a></li>
      </ul>
    </guvam-dropdown>
  </Code>
</Layout>
