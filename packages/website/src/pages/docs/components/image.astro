---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import chipImage from '../../../assets/components/chip-image.webp';
import Badge from '../../../components/blocks/Badge.astro';
import { Image } from 'astro:assets';

---
<Layout title="Image Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Image</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>

    <tr>
      <td>.fluid</td>
      <td><Badge type="modifier" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Input</Title>
  <Code lang="html" type="inline">
    <Image class="Image" src={chipImage} alt="" />
  </Code>

</Layout>
