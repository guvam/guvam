---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Input Group Group Guvam Component">
  <h1 class="Text type-h1 margin">Input Group</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.InputGroup</td>
      <td>
        <Badge type="class" />
      </td>
      <td></td>
    </tr>
    <tr>
      <td>.InputGroup-Text</td>
      <td>
        <Badge type="class" />
      </td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input-group">Input Group</Title>
  <Code lang="html" type="list">
      <div class="InputGroup">
        <span class="InputGroup-Text">@</span>
        <input type="text" class="Input" />
      </div>

      <div class="InputGroup">
        <input type="text" class="Input" />
        <span class="InputGroup-Text">@</span>
        <input type="text" class="Input" />
      </div>

      <div class="InputGroup">
        <input type="text" class="Input" />
        <span class="InputGroup-Text">.com</span>
      </div>

      <div class="InputGroup">
        <span class="InputGroup-Text">Text area</span>
        <textarea class="Input type-textarea"></textarea>
      </div>
  </Code>

  <Title id="input-group-multiple">Multiple addons and inputs</Title>
  <Code lang="html" type="list">
      <div class="InputGroup">
        <span class="InputGroup-Text">First and last name</span>
        <input type="text" class="Input" />
        <input type="text" class="Input" />
      </div>

      <div class="InputGroup">
        <span class="InputGroup-Text">$</span>
        <span class="InputGroup-Text">0.00</span>
        <input type="text" class="Input" />
      </div>

      <div class="InputGroup">
        <input type="text" class="Input" />
        <span class="InputGroup-Text">.com</span>
      </div>
  </Code>

  <Title id="input">Components in addons</Title>
  <Code lang="html" type="list">
      <div class="InputGroup">
        <button class="Button InputGroup-Text">First and last name</button>
        <input type="text" class="Input" />
      </div>

      <div class="InputGroup">
        <span class="InputGroup-Text">
          <input type="radio" class="Radio">
        </span>

        <span class="InputGroup-Text">
          <input type="checkbox" class="Switch">
        </span>
        <input type="text" class="Input" />
      </div>
  </Code>
</Layout>
