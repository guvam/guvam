---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Link Guvam Component">
  <h1 class="Text type-h1 margin">Link</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Link</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>
    <tr>
      <td>.type-undecorated</td>
      <td><Badge type="modifier" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="link">Link</Title>
  <Code lang="html" type="inline">
    <a href="#" class="Link"> Link to the past </a>
  </Code>
  <Title id="link-undecorated">Link undecorated</Title>
  <Code lang="html" type="inline">
    <a href="#" class="Link type-undecorated"> Link to the past </a>
  </Code>
</Layout>
