---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Loading Guvam Component">
  <h1 class="Text type-h1 margin">Loading</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Loading</td>
      <td><Badge type="class" /></td>
      <td>Loading element style</td>
    </tr>
    </tbody>
  </table>

  <Title id="loading">Loading Spinner</Title>
  <Code lang="html" type="inline">
    <div class="Loading"></div>
  </Code>
</Layout>
