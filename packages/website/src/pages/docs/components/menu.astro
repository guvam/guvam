---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Dropdown } from '@guvam/guvam';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Menu Guvam Component">
  <h1 class="Text type-h1 margin">Menu</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Menu</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Dropdown client:load />
  <Title id="dropdown">Dropdown</Title>
  <Code lang="html" type="block">
    <guvam-dropdown class="Menu">
      <button class="Button" data-target="button">
        Menu
      </button>
      <ul class="Menu-Dropdown">
        <li class="Menu-Item"><input type="text" class="Input"/></li>
        <div class="Menu-Separator" />
        <li><a class="Menu-Item" href="#">Action</a></li>
        <li><a class="Menu-Item" href="#">Another action</a></li>
        <div class="Menu-Separator" />
        <li><a class="Menu-Item" href="#">Something else here</a></li>
      </ul>
    </guvam-dropdown>
  </Code>

</Layout>
