---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';


---
<Layout title="Modal Guvam Component">
  <h1 class="Text type-h1 margin">Modal</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-input</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>.Modal</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td></td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Modal styling</Title>
  <Code lang="html" type="inline">
    <dialog open class="Modal type-static">
      <h1 class="Modal-Heading">Modal Heading</h1>
      <div class="Modal-Body type-bordered">
        Et voluptatem sit eveniet inventore quis natus et.
        Voluptatem voluptates dolores dolores.
        Illum qui occaecati incidunt ipsam atque quos ab.
        Aperiam est voluptatem exercitationem.
        Delectus magnam dolor vitae aperiam iure.
        Praesentium nihil quo ea eligendi ut et mollitia accusantium.

      </div>
      <div class="Modal-Footer">
        <button class="Button type-outline">close</button>
        <button class="Button">Save Changes</button>
      </div>
    </dialog>
  </Code>

  <Title id="input">Modal in action</Title>
  <Code lang="html" type="inline">
    <button class="Button" data-modal-opener>Click me</button>
    <dialog class="Modal" data-modal>
      <h1 class="Modal-Heading">Modal Heading</h1>
      <div class="Modal-Body type-bordered">
          Modal Body
      </div>
      <form class="Modal-Footer">
        <button class="Button type-outline">close</button>
        <button class="Button">Save Changes</button>
      </form>
    </dialog>


    <script is-inline>
      const modalButton= document.querySelector('[data-modal-opener]');
      const modal= document.querySelector('[data-modal]')

      modalButton.addEventListener('click', ()=>  modal.showModal())
    </script>
  </Code>
</Layout>
