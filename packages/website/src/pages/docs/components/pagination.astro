---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Pagination Guvam Component">
  <h1 class="Text type-h1 margin">Pagination</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Pagination</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>
    <tr>
      <td>.Pagination-Link</td>
      <td><Badge type="class" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Pagination</Title>
  <Code lang="html" type="inline">
    <nav class="Pagination">
      <a class="Pagination-Link" href="#">Previous</a>
      <a class="Pagination-Link" href="#">1</a>
      <a class="Pagination-Link" href="#">2</a>
      <a class="Pagination-Link" href="#">3</a>
      <a class="Pagination-Link" href="#">4</a>
      <a class="Pagination-Link" href="#">Next</a>
    </nav>
  </Code>

</Layout>
