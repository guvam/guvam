---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---
<Layout title="Pagination Guvam Component">
  <h1 class="Text type-h1 margin">Pagination</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-input</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>.Pagination</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td></td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Pagination</Title>
  <Code lang="html" type="inline">
    <ul class="Pagination">
      <li>
        <label><input type="radio" name="doc-pagination">1</label>
      </li>
      <li>
        <label><input type="radio" name="doc-pagination">2</label>
      </li>
      <li>
        <label><input type="radio" name="doc-pagination">3</label>
      </li><li>
        <label><input type="radio" name="doc-pagination">4</label>
      </li>
    </ul>
  </Code>

</Layout>
