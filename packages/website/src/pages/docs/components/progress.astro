---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Progress Guvam Component">
  <h1 class="Text type-h1 margin">Progress</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Progress</td>
      <td><Badge type="class" /></td>
      <td>Progress element style</td>
    </tr>
    <tr>
      <td>.linear</td>
      <td><Badge type="modifier"></Badge></td>
      <td>Linear progress bar</td>
    </tr>
    </tbody>
  </table>

  <Title id="progress">Progress</Title>
  <Code lang="html" type="inline">
    <progress class="Progress" value="70" max="100" />
  </Code>

  <Title id="progress-indeterminate">Progress Indeterminate</Title>
  <Code lang="html" type="inline">
    <progress class="Progress" />
  </Code>



</Layout>
