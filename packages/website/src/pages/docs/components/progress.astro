---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---
<Layout title="Progress Guvam Component">
  <h1 class="Text type-h1 margin">Progress</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Class name</td>
      <td>Type</td>
      <td></td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-input</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>.Progress</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td>modifier modifier modifier</td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Progress Indeterminate</Title>
  <Code lang="html" type="inline">
    <div class="Progress" />
  </Code>

  <Title id="input">Progress Linear</Title>
  <Code lang="html" type="inline">
    <div class="Progress linear" />
  </Code>


</Layout>
