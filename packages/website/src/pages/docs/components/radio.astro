---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Radio Guvam Component">
  <h1 class="Text type-h1 margin">Radio Button</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          input [type="radio"]
        </td>
        <td>
          <Badge type="element">element</Badge>
        </td>
        <td>Radio HTML Element</td>
      </tr>
      <tr>
        <td>.Radio</td>
        <td><Badge type="class"></Badge></td>
        <td>Radio element style</td>
      </tr>
      <tr>
        <td>[checked]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Active radio element</td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Disabled radio element</td>
      </tr>
    </tbody>
  </table>

  <Title id="radio">Radio Button</Title>
  <Code lang="html">
    <label>
      <input class="Radio" type="radio" name="doc-radio"> 1
    </label>
    <label>
      <input class="Radio" type="radio" name="doc-radio"> 2
    </label>

  </Code>


  <Title id="radio">Radio Button disabled</Title>
  <Code lang="html">
    <label>
      <input class="Radio" type="radio" checked name="doc-radio-disabled" disabled> 1
    </label>
    <label>
      <input class="Radio" type="radio" name="doc-radio-disabled" disabled> 2
    </label>
    <label>
      <input class="Radio" type="radio" name="doc-radio-disabled" disabled> 3
    </label>
  </Code>


</Layout>
