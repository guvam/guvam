---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---
<Layout title="Slider Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Class name</td>
      <td>Type</td>
      <td></td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-input</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>.Input</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td>modifier modifier modifier</td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="input">Input</Title>
  <Code lang="html" type="inline">
    <input type="range" class="Slider" />
  </Code>

  <Title id="input">Input Disabled</Title>
  <Code lang="html" type="inline">
    <input type="range" class="Slider" disabled />
  </Code>

</Layout>
