---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Slider Guvam Component">
  <h1 class="Text type-h1 margin">Slider</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>.Slider</td>
      <td><Badge type="style" /></td>
      <td></td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td><Badge type="modifier" /></td>
      <td></td>
    </tr>
    </tbody>
  </table>

  <Title id="slider">Slider</Title>
  <Code lang="html" type="inline">
    <input type="range" class="Slider"/>
  </Code>

  <Title id="Slider disabled">Input Disabled</Title>
  <Code lang="html" type="inline">
    <input type="range" class="Slider" disabled />
  </Code>

</Layout>
