---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---
<Layout title="Switch Guvam Component">
  <h1 class="Text type-h1 margin">Switch</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Switch</td>
        <td>component</td>
        <td></td>
      </tr>
      <tr>
        <td>.type-outline</td>
        <td>modifier</td>
        <td></td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td>attribute</td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Title id="switch">Switch</Title>
  <Code lang="html">
    <label>
      <input class="Switch" type="checkbox" >
    </label>
    <label>
      <input class="Switch" type="checkbox" checked>
    </label>
  </Code>

  <Title id="switch">Switch Disabled</Title>
  <Code lang="html">
    <label>
      <input class="Switch" type="checkbox"  disabled>
    </label>
    <label>
      <input class="Switch" type="checkbox" checked disabled>
    </label>
  </Code>



</Layout>
