---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Switch Guvam Component">
  <h1 class="Text type-h1 margin">Switch</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          input [type="checkbox"]
        </td>
        <td>
          <Badge type="element">element</Badge>
        </td>
        <td>Switch HTML Element</td>
      </tr>
      <tr>
        <td>.Switch</td>
        <td><Badge type="class"></Badge></td>
        <td>Switch element style</td>
      </tr>
      <tr>
        <td>[checked]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Toggled on switch</td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td><Badge type="attribute"></Badge></td>
        <td>Disabled switch element</td>
      </tr>
    </tbody>
  </table>

  <Title id="switch">Switch</Title>
  <Code lang="html">
    <label>
      <input class="Switch" type="checkbox" >
    </label>
    <label>
      <input class="Switch" type="checkbox" checked>
    </label>
  </Code>

  <Title id="switch">Switch Disabled</Title>
  <Code lang="html">
    <label>
      <input class="Switch" type="checkbox"  disabled>
    </label>
    <label>
      <input class="Switch" type="checkbox" checked disabled>
    </label>
  </Code>



</Layout>
