---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---

<Layout title="Table Guvam Component">
  <h1 class="Text type-h1 margin">Input</h1>
  <table class="Table">
    <thead>
      <tr>
        <td>Name</td>
        <td>Type</td>
        <td>Description</td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>guvam-input</td>
        <td>element</td>
        <td></td>
      </tr>
      <tr>
        <td>.Input</td>
        <td>style</td>
        <td></td>
      </tr>
      <tr>
        <td>.type-outline</td>
        <td>modifier</td>
        <td></td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td>attribute</td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Title id="input">Input</Title>
  <Code lang="html" type="inline">
    <table class="Table">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">First Name</th>
          <th scope="col">Last Name</th>
          <th scope="col">Id</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">1</th>
          <td>Jeff</td>
          <td>Brown</td>
          <td>0101920</td>
        </tr>
        <tr>
          <th scope="row">2</th>
          <td>Jake</td>
          <td>Gray</td>
          <td>0102921</td>
        </tr>
        <tr>
          <th scope="row">3</th>
          <td>Dave</td>
          <td>Black</td>
          <td>01030922</td>
        </tr>
      </tbody>
    </table>
  </Code>
</Layout>
