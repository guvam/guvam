---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
import { Tabs } from '@guvam/guvam';
import Badge from '../../../components/blocks/Badge.astro';
---
<Layout title="Tabs Guvam Component">
  <h1 class="Text type-h1 margin">Tabs</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>
        guvam-tabs
      </td>
      <td>
        <Badge type="element"></Badge>
      </td>
      <td>Tabs Element</td>
    </tr>
    <tr>
      <td>Tab-Headers</td>
      <td><Badge type="target"></Badge></td>
      <td>Headers container</td>
    </tr>
    <tr>
      <td>Tab-Contents</td>
      <td><Badge type="target"></Badge></td>
      <td>Contents container</td>
    </tr>
    <tr>
      <td>.Tabs</td>
      <td><Badge type="class"></Badge></td>
      <td>Tabs element style</td>
    </tr>
    </tbody>
  </table>

  <Tabs client:load />
  <Title id="tabs">Tabs</Title>
  <Code lang="html" type="block">
    <guvam-tabs class="Tabs">
      <div class="Tab-Headers" data-target="Tab-Headers">
        <button class="Button type-text">
          tab1
        </button>
        <button class="Button type-text">
          tab2
        </button>
        <button class="Button type-text">
          tab3
        </button>
      </div>

      <div class="Tab-Contents Card" data-target="Tab-Contents">
        <div>content1</div>
        <div>content2</div>
        <div>content3</div>
      </div>

    </guvam-tabs>
  </Code>
</Layout>
