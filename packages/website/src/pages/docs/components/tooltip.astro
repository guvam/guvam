---
import Layout from '../../../components/docs/Layout.astro';
import Title from '../../../components/blocks/Title.astro';
import Code from '../../../components/blocks/Code.astro';
---
<Layout title="Tooltip Guvam Component">
  <h1 class="Text type-h1 margin">Tooltip</h1>
  <table class="Table">
    <thead>
    <tr>
      <td>Name</td>
      <td>Type</td>
      <td>Description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>guvam-input</td>
      <td>element</td>
      <td></td>
    </tr>
    <tr>
      <td>.Tooltip</td>
      <td>style</td>
      <td></td>
    </tr>
    <tr>
      <td>.type-outline</td>
      <td>modifier</td>
      <td></td>
    </tr>
    <tr>
      <td>[disabled]</td>
      <td>attribute</td>
      <td></td>
    </tr>
    </tbody>
  </table>



  <Title id="input">Tooltip</Title>
  <Code lang="html" type="inline">
    <div class="has-tooltip">
        <button class="Button Tooltip-Target">button</button>
        <span class="Tooltip bottom">tooltip</span>

    </div>

  </Code>


  <Title id="input">Tooltip directions</Title>
  <Code lang="html" type="inline">
    <div class="has-tooltip">
        <div class="Card type-square Tooltip-Target" style="  inline-size:300px;block-size:300px;">
          Hover over me
        </div>
        <span class="Tooltip top-left">tooltip</span>
        <span class="Tooltip top">tooltip</span>
        <span class="Tooltip top-right">tooltip</span>

        <span class="Tooltip right-start">tooltip</span>
        <span class="Tooltip right">tooltip</span>
        <span class="Tooltip right-end">tooltip</span>

        <span class="Tooltip left">tooltip</span>
        <span class="Tooltip left-start">tooltip</span>
        <span class="Tooltip left-end">tooltip</span>

        <span class="Tooltip bottom">tooltip</span>
        <span class="Tooltip bottom-right">tooltip</span>
        <span class="Tooltip bottom-left">tooltip</span>
    </div>

  </Code>

</Layout>
