---
import { Select } from '@guvam/elements';
import Layout from '../../components/docs/Layout.astro';
import Code from '../../components/blocks/Code.astro';
import Title from '../../components/blocks/Title.astro';
import codeCss from '../../elements/Clipboard.css?raw';
import codeTs from '../../elements/Clipboard.ts?raw';
import codeHtml from '../../elements/Clipboard.astro?raw';
import light from 'bootstrap-icons/icons/lightbulb.svg?raw';
import dark from 'bootstrap-icons/icons/moon-fill.svg?raw';
import down from 'bootstrap-icons/icons/chevron-down.svg?raw';
import './_input.css';
---
<Layout title="examples select">
  <h1 class="Text type-h1 margin">Content & Display</h1>
  <Title id="avatar-section">class .Avatar</Title>
  <Title id="badge-section">class .Badge</Title>
  <Title id="chip-section">class .Chip</Title>
  <Title id="icon-section">class .Icon</Title>
  <Title id="image-section">class .Image</Title>
  <Title id="list-section">class .List</Title>
  <Title id="table-section">class .Table</Title>
  <Title id="text-section">class .Text</Title>
</Layout>
