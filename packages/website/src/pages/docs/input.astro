---
import { Select } from '@guvam/elements';
import Layout from '../../components/docs/Layout.astro';
import Code from '../../components/docs/blocks/Code.astro';
import code from 'packages/website/src/components/docs/code-highlighter.ts?raw';
import Title from '../../components/docs/blocks/Title.astro';
import light from '../../assets/icons/light.svg?raw';
import dark from '../../assets/icons/dark.svg?raw';
import down from '../../assets/icons/arrow-down.svg?raw';
---
<Layout title="examples select">

  <Title title="Button" id="button-section" />

  <!--<table>
    <thead>
    <tr>
      <td>class</td>
      <td>type</td>
      <td>description</td>
    </tr>
    </thead>
    <tbody>
    <tr>
      <td>Button</td>
      <td>type</td>
      <td>description</td>
    </tr>
    <tr>
      <td>class</td>
      <td>type</td>
      <td>description</td>
    </tr>
    <tr>
      <td>class</td>
      <td>type</td>
      <td>description</td>
    </tr>
    </tbody>
  </table>

  <Code lang="js" title="high-light.js" code={code} />-->
  <p style="display: flex; gap: 1em; flex-wrap: wrap">
    <button class="Button">Button</button>
    <button class="Button" disabled>Button</button>
    <button class="Button type-outline">Button</button>
    <button class="Button type-text">Button</button>
    <button class="Button type-link">Button</button>
    <button class="Button icon">A</button>
    <button class="Button icon">
      <Fragment set:html={dark} />
    </button>
    <button class="Button inline-wide">Button</button>
    <button class="Button">
      <Fragment set:html={light} />
      Button
    </button>

    <button class="Button">
      Select me Button
      <Fragment set:html={down} />
    </button>
  </p>

  <Title title="Input" id="input-section" />
  <p style="display: flex; gap: 1em; flex-wrap: wrap">
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input type-outline" />
    <input type="text" placeholder="placeholder" class="Input" disabled />
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input" />
    <input type="text" placeholder="placeholder" class="Input" />
  </p>


  <!--

    <Title title="Textarea" id="Textarea-section" />
