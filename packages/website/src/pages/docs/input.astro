    <Title title="Checkbox" id="checkbox-section" />
    <Title title="Radio" id="radio-section" />
    <Title title="Switch" id="switch-section" />
    <Title title="Rate" id="rate-section" />
    <Title title="Slider" id="slider-section" />
  -->

</Layout>
