---
import Layout from '../../components/docs/Layout.astro';
import Title from '../../components/blocks/Title.astro';
import './_input.css';
import Slides from '../../elements/Slides/Slides.astro';
import SlidesImage from '../../elements/Slides/SlidesImage.astro';
---

<Layout title="examples select">
  <h1 class="Text type-h1 margin">Layout</h1>
  <Title id="container-section">class .Container</Title>
  <Title id="card-section">class .Card</Title>
  <Title id="list-section">class .List</Title>
  <Title id="dialog-section">class .Dialog</Title>
  <Title id="accordion-section">class .Accordion</Title>
  <div class="DocsTable">
    <div>
      <ul class="Accordion">
        {
          [1, 2, 3, 4, 5].map((x) => (
            <li>
              <div>Title</div>
              <div>
                It’s common to build DIY air purifiers by basically strapping a filter to a fanIt’s common to build DIY air purifiers by
                basically strapping a filter to a fanIt’s common to build DIY air purifiers by basically strapping a filter to a fanIt’s
                common to build DIY air purifiers by basically strapping a filter to a fanIt’s common to build DIY air purifiers by
                basically strapping a filter to a fan
              </div>
            </li>
          ))
        }
      </ul>
    </div>
    <div>.Button [disabled]</div>
    <div>disabled</div>
  </div>
  <Title id="tabs-section">class .Tabs</Title>
  <Title id="slides-section">class .Slides</Title>
  <div class="DocsTable">
    <div>
      <Slides>
        <SlidesImage />
      </Slides>
    </div>
    <div>.Button [disabled]</div>
    <div>disabled</div>
  </div>
  <Title id="form-section">class .Form</Title>
</Layout>
