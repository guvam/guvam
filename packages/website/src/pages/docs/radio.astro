  <table class="Table">
    <thead>
      <tr>
        <td>Class name</td>
        <td>Type</td>
        <td></td>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Radio Button</td>
        <td>component</td>
        <td></td>
      </tr>
      <tr>
        <td>.type-outline</td>
        <td>modifier</td>
        <td>modifier modifier modifier</td>
      </tr>
      <tr>
        <td>[disabled]</td>
        <td>attribute</td>
        <td></td>
      </tr>
    </tbody>
  </table>

  <Title id="radio">Radio Button with link</Title>
  <Code lang="html">
    <label>
      <input class="Radio" type="radio" name="doc-radio"> 1
    </label>
    <label>
      <input class="Radio" type="radio" name="doc-radio"> 2
    </label>
  </Code>




</Layout>
